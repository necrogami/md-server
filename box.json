{
    "directories": [
        "src",
        "config",
        "templates",
        "assets"
    ],
    "files": [
        "router.php",
        ".env"
    ],
    "finder": [
        {
            "in": "vendor",
            "name": "*.php",
            "exclude": [
                "tests",
                "test",
                "Tests",
                "docs",
                "doc"
            ]
        },
        {
            "in": "vendor",
            "name": ["*.js", "*.css", "*.woff2", "*.woff", "*.ttf", "*.template", "*.xml", "*.xsd", "*.yaml", "*.yml", "*.twig", "*.bash", "*.zsh", "*.fish", "*.svg", "*.base64", "*.exe"],
            "exclude": [
                "tests",
                "test",
                "Tests",
                "docs",
                "doc"
            ]
        }
    ],
    "main": "bin/md-server",
    "output": "md-server.phar",
    "stub": true,
    "compression": "GZ",
    "check-requirements": false
}
