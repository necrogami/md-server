{
    "name": "md-server/md-server",
    "description": "A portable Markdown documentation server",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.2",
        "symfony/runtime": "^7.0",
        "symfony/http-kernel": "^7.0",
        "symfony/routing": "^7.0",
        "symfony/console": "^7.0",
        "symfony/yaml": "^7.0",
        "symfony/mime": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "twig/twig": "^3.0",
        "symfony/twig-bundle": "^7.0",
        "league/commonmark": "^2.0",
        "react/http": "^1.11",
        "nyholm/psr7": "^1.8",
        "symfony/psr-http-message-bridge": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/browser-kit": "^7.0",
        "symfony/css-selector": "^7.0",
        "pestphp/pest": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "MdServer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MdServer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "auto-scripts": {},
        "test": "phpunit"
    },
    "extra": {
        "runtime": {
            "class": "Symfony\\Component\\Runtime\\SymfonyRuntime"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "pestphp/pest-plugin": true
        }
    }
}
