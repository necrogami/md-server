{# templates/404.html.twig #}
{% extends 'layout.html.twig' %}

{% block title %}Not Found — md-server{% endblock %}

{% block content %}
<article class="md-article markdown-body">
    <h1>Page Not Found</h1>
    <p>The page <code>{{ path }}</code> could not be found.</p>
