{# templates/page.html.twig #}
{% extends 'layout.html.twig' %}

{% block title %}{{ page.title }} — md-server{% endblock %}

{% block content %}
<div class="md-content-body">
    <article class="md-article markdown-body">
        {{ page.renderedHtml|raw }}
    </article>
    <nav class="md-toc" aria-label="On this page">
        <div class="md-toc-title">On this page</div>
        <ul class="md-toc-list"></ul>
    </nav>
</div>
{% endblock %}
